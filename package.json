{
  "name": "open-enterprise-ui",
  "version": "0.1.0",
  "description": "Open-source enterprise UI components for data-heavy products.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "author": "OdiriTeddie",
  "homepage": "https://github.com/OdiriTeddie/open-enterprise-ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OdiriTeddie/open-enterprise-ui.git"
  },
  "bugs": {
    "url": "https://github.com/OdiriTeddie/open-enterprise-ui/issues"
  },
  "keywords": [
    "react",
    "vue",
    "typescript",
    "ui",
    "data-grid",
    "enterprise",
    "components"
  ],
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "dev": "pnpm --filter @open-enterprise-ui/react dev",
