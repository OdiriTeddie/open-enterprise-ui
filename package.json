    "typecheck": "pnpm --filter @open-enterprise-ui/react typecheck",
    "lint": "pnpm --filter @open-enterprise-ui/react lint",
    "test": "pnpm --filter @open-enterprise-ui/react test",
    "preview": "pnpm --filter @open-enterprise-ui/react preview"
  }
